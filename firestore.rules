/**
 * TRANSITIONAL Firestore Security Rules (Story 1.2)
 *
 * Auth has migrated to Supabase. Next.js middleware now protects all routes.
 * Client-side Firestore reads are allowed for any request (middleware handles auth).
 * Writes remain restricted to ADMIN via Firebase custom claims (Server Actions use firebase-admin).
 *
 * This ruleset will be REMOVED when Firebase is decommissioned (Story 1.9).
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user has ADMIN role via Firebase custom claims
    // (only relevant for direct Firestore writes, which use firebase-admin and bypass rules)
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'ADMIN';
    }

    // Users collection — read own profile, admin writes
    match /users/{userId} {
      allow read: if true;  // Protected by Next.js middleware
      allow write: if isAdmin();
    }

    // Orders — read allowed (middleware protected), write admin only
    match /orders/{countryCode}/orders/{orderId} {
      allow read: if true;  // Protected by Next.js middleware
      allow write: if isAdmin();
    }

    // Roles admin — read only
    match /roles_admin/{userId} {
      allow read: if true;  // Protected by Next.js middleware
      allow write: if false;
    }

    // Settings — read allowed, write admin only
    match /settings/{settingId} {
      allow read: if true;  // Protected by Next.js middleware
      allow write: if isAdmin();
    }

    // Metrics — read allowed, write admin only
    match /metrics/{metricId} {
      allow read: if true;  // Protected by Next.js middleware
      allow write: if isAdmin();
    }
  }
}
