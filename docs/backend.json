{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the MisterTuga Insights application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user entity."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "Role of the user (e.g., ADMIN, BASIC)."
        }
      },
      "required": [
        "id",
        "email",
        "role"
      ]
    },
    "ProfitStat": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ProfitStat",
      "type": "object",
      "description": "Represents profit statistics data for a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the profit stat entry."
        },
        "userId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N ProfitStat)"
        },
        "date": {
          "type": "string",
          "description": "Date for which the profit stat is recorded.",
          "format": "date-time"
        },
        "profit": {
          "type": "number",
          "description": "Profit amount for the recorded date."
        }
      },
      "required": [
        "id",
        "userId",
        "date",
        "profit"
      ]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents a Shopify order.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the order."
        },
        "country": {
          "type": "string"
        },
        "countryCode": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "status": {
          "type": "string",
          "enum": ["Pending Production", "Shipped"]
        },
        "customer": {
          "$ref": "#/backend/entities/Customer"
        },
        "trackingNumber": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/Product"
          }
        }
      },
      "required": ["id", "country", "countryCode", "date", "status", "customer", "items"]
    },
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer.",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        }
      },
      "required": ["name", "address", "phone"]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product in an order.",
      "properties": {
        "name": {
          "type": "string"
        },
        "productId": {
          "type": "string"
        },
        "customization": {
          "type": "string"
        },
        "size": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        },
        "thumbnailUrl": {
          "type": "string"
        }
      },
      "required": ["name", "productId", "customization", "size", "quantity", "thumbnailUrl"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profile information. Authorization is based on matching request.auth.uid to the userId.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user."
            }
          ]
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "AdminRole",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Documents in this collection signify that the user has an ADMIN role. Existence of the document is sufficient; content is ignored.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user who is an admin."
            }
          ]
        }
      },
       {
        "path": "/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": {
            "$ref": "#/backend/entities/Order"
          },
          "description": "Stores all Shopify orders in a single, shared collection.",
          "params": [
            {
              "name": "orderId",
              "description": "The unique identifier of the order."
            }
          ]
        }
      }
    ],
    "reasoning": "This Firestore structure prioritizes security and scalability by adhering to the principles of Authorization Independence, Structural Segregation, and Access Modeling. User data is stored in a separate collection to ensure clear ownership and access control. The top-level 'orders' collection is shared among all authenticated users to facilitate a collaborative workflow. This design eliminates the need for `get()` calls in security rules for standard user authorization because it's based solely on the `request.auth.uid` matching the `userId` in the path."
  }
}
